# ─── REDLINE Environment Configuration ───
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit the actual .env file!

# ─── Database ───
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# ─── Application ───
APP_ENV=development
APP_DEBUG=false
APP_URL=

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=

# ─── Security ───
CSRF_SECRET=
ALLOWED_ORIGIN=
